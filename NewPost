import React, { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useNavigate } from 'react-router-dom';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Flame, Lightbulb, Megaphone, CloudLightning, Send } from 'lucide-react';

const postTypes = [
  { value: 'journey', label: 'Journey Update', icon: Flame, desc: 'Share your progress' },
  { value: 'tip', label: 'Tip / Trick', icon: Lightbulb, desc: 'Help others fight urges' },
  { value: 'motivation', label: 'Motivation', icon: Megaphone, desc: 'Inspire the community' },
  { value: 'vent', label: 'Vent', icon: CloudLightning, desc: 'Let it out, no judgment' },
];

export default function NewPost() {
  const navigate = useNavigate();
  const [currentUser, setCurrentUser] = useState(null);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [form, setForm] = useState({
    title: '',
    content: '',
    type: 'journey',
    addiction_type: '',
  });

  useEffect(() => {
    base44.auth.me().then(setCurrentUser).catch(() => {});
  }, []);

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (!form.title.trim() || !form.content.trim()) return;
    setIsSubmitting(true);
    await base44.entities.Post.create({
      ...form,
      author_name: currentUser?.full_name || 'Anonymous',
      likes: 0,
      liked_by: [],
      comments_count: 0,
    });
    navigate('/');
  };

  return (
    <div className="max-w-2xl mx-auto">
      <div className="mb-8">
        <h1 className="font-heading text-2xl md:text-3xl font-bold tracking-tight mb-2">
          Share Your Story
        </h1>
        <p className="text-muted-foreground text-sm">
          Your experience could save someone else. Be raw. Be real.
        </p>
      </div>

      <form onSubmit={handleSubmit} className="space-y-6">
        {/* Post Type */}
        <div className="space-y-3">
          <Label className="font-heading font-medium">What kind of post?</Label>
          <div className="grid grid-cols-2 gap-3">
            {postTypes.map(({ value, label, icon: Icon, desc }) => (
              <button
                key={value}
                type="button"
                onClick={() => setForm({ ...form, type: value })}
                className={`text-left p-4 rounded-xl border transition-all ${
                  form.type === value
                    ? 'border-primary bg-primary/5'
                    : 'border-border bg-card hover:border-muted-foreground/30'
                }`}
              >
                <Icon className={`w-5 h-5 mb-2 ${form.type === value ? 'text-primary' : 'text-muted-foreground'}`} />
                <p className="font-medium text-sm">{label}</p>
                <p className="text-xs text-muted-foreground mt-0.5">{desc}</p>
              </button>
            ))}
          </div>
        </div>

        {/* Title */}
        <div className="space-y-2">
          <Label className="font-heading font-medium">Title</Label>
          <Input
            value={form.title}
            onChange={(e) => setForm({ ...form, title: e.target.value })}
            placeholder="Give it a strong title..."
            className="bg-secondary border-border text-lg font-heading"
          />
        </div>

        {/* Content */}
        <div className="space-y-2">
          <Label className="font-heading font-medium">Your Story</Label>
          <Textarea
            value={form.content}
            onChange={(e) => setForm({ ...form, content: e.target.value })}
            placeholder="Be honest. Be raw. Share what you're going through..."
            className="bg-secondary border-border min-h-[180px] leading-relaxed"
          />
        </div>

        {/* Addiction Type */}
        <div className="space-y-2">
          <Label className="font-heading font-medium">Related Addiction (optional)</Label>
          <Input
            value={form.addiction_type}
            onChange={(e) => setForm({ ...form, addiction_type: e.target.value })}
            placeholder="e.g. Smoking, Alcohol, Social Media..."
            className="bg-secondary border-border"
          />
        </div>

        <Button
          type="submit"
          disabled={isSubmitting || !form.title.trim() || !form.content.trim()}
          className="w-full bg-primary hover:bg-primary/90 font-heading font-semibold text-base h-12"
        >
          <Send className="w-4 h-4 mr-2" />
          {isSubmitting ? 'Posting...' : 'Post It'}
        </Button>
      </form>
    </div>
  );
}
